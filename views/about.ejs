<%- include('partials/head') %>
    <%- include('partials/header') %>

        <main id="content" class="flex-1 relative z-10 w-full mb-16">
            <div class="max-w-4xl mx-auto view-transition px-4 md:px-0">
                <div class="card rounded-[40px] p-8 md:p-16 relative overflow-hidden">
                    <div class="absolute -top-24 -right-24 w-64 h-64 bg-micRed/20 blur-[100px] rounded-full"></div>
                    <div class="relative z-10">
                        <span class="text-micRed font-mono text-[10px] tracking-[0.3em] mb-4 block">Our Story</span>
                        <h1 class="text-4xl md:text-6xl font-black tracking-tighter mb-8 text-white">About Us</h1>

                        <div class="space-y-6 text-gray-300 text-lg md:text-xl leading-relaxed">
                            <p>We are a syndicate of tech enthusiasts based in Nairobi, sharing deep dives into the
                                software development scene, vibe coding, and the future of engineering.</p>
                            <p>Built on code, curiosity, and conversations Tech House Podcast decodes the stack,
                                challenges the defaults, and ships ideas every Thursday. From open-source to AI, we
                                debug the tech world so you don't have to.</p>
                            <p class="text-white font-semibold">Bringing you the latest from the world of technology.
                            </p>
                        </div>

                        <h3 class="text-2xl font-black text-white mt-12 mb-6 tracking-tighter">The Hosts</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                            <div class="bg-white/5 border border-white/10 rounded-3xl p-6 flex items-center gap-4">
                                <div class="w-16 h-16 rounded-full flex-shrink-0"
                                    style="background: linear-gradient(135deg, #FF2E2E, #FF8A00);"></div>
                                <div>
                                    <h4 class="font-bold text-white text-lg">Kaka</h4>
                                </div>
                            </div>
                            <div class="bg-white/5 border border-white/10 rounded-3xl p-6 flex items-center gap-4">
                                <div class="w-16 h-16 rounded-full flex-shrink-0"
                                    style="background: linear-gradient(135deg, #6C63FF, #E52E71);"></div>
                                <div>
                                    <h4 class="font-bold text-white text-lg">Sila</h4>
                                </div>
                            </div>
                            <div class="bg-white/5 border border-white/10 rounded-3xl p-6 flex items-center gap-4">
                                <div class="w-16 h-16 rounded-full flex-shrink-0"
                                    style="background: linear-gradient(135deg, #00C9A7, #0077B6);"></div>
                                <div>
                                    <h4 class="font-bold text-white text-lg">Caleb</h4>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
            </div> <!-- close #app -->
            <%- include('partials/player') %>
                <%- include('partials/dock') %>

                    <script src="/js/main.js"></script>
                    </body>

                    </html>